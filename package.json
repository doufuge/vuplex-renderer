{
  "name": "@vue-vuplex/renderer",
  "version": "0.1.1",
  "description": "Web ↔ Vuplex IPC communication layer for renderer (WebView) side",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/global.d.ts dist/global.d.ts",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "devDependencies": {
    "typescript": "~6.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
